// ============================================================
// SETTINGS SCREEN (Volume + Calibration + Auto Sleep)
// ============================================================
int settingsField = 0;
const int SETTINGS_COUNT = 5;

// Auto-sleep timeout options (milliseconds, 0=disabled)
const unsigned long sleepOptions[] = {0, 30000, 60000, 120000, 300000};
const char* sleepLabels[] = {"Kapali", "30sn", "1dk", "2dk", "5dk"};
const int SLEEP_OPTION_COUNT = 5;
int sleepOptionIndex = 2;  // Default: 1dk (60000ms)

int getSleepOptionIndex() {
  for (int i = 0; i < SLEEP_OPTION_COUNT; i++) {
    if (sleepOptions[i] == sleepTimeoutMs) return i;
  }
  return 0;
}

void drawSettingsScreen(bool full) {
  if (full) {
    tft.fillScreen(CYBER_BG); tft.setTextSize(2); tft.setCursor(16,10);
    tft.setTextColor(CYBER_LIGHT); tft.print("AYARLAR"); drawAlarmIcon();
    sleepOptionIndex = getSleepOptionIndex();
  }

  const char* labels[] = {"Ses:", "Sicaklik:", "Nem:", "Oto Uyku:", "Alarm Sesi:"};
  char values[5][20];
  sprintf(values[0], "%d%%", volumeLevel);
  if (tempOffset >= 0) sprintf(values[1], "+%.1fC", tempOffset);
  else sprintf(values[1], "%.1fC", tempOffset);
  if (humOffset >= 0) sprintf(values[2], "+%.1f%%", humOffset);
  else sprintf(values[2], "%.1f%%", humOffset);
  sprintf(values[3], "%s", sleepLabels[sleepOptionIndex]);
  sprintf(values[4], "%s", rtttlNames[selectedAlarm]);

  for (int i = 0; i < SETTINGS_COUNT; i++) {
    int y = 38 + i * 37;
    tft.fillRect(8, y-2, 304, 34, CYBER_BG);
    tft.setTextSize(1);
    tft.setTextColor(CYBER_DARK);
    tft.setCursor(16, y); tft.print(labels[i]);
    tft.setTextSize(2);
    if (i == settingsField) {
      tft.setTextColor(CYBER_LIGHT, CYBER_BG);
    } else {
      tft.setTextColor(ST77XX_WHITE, CYBER_BG);
    }
    tft.setCursor(16, y + 14); tft.print(values[i]);
    if (i == settingsField) {
      tft.setTextColor(CYBER_ACCENT);
      tft.setCursor(295, y + 14); tft.print("<");
    }
  }

  tft.fillRect(0, 225, 320, 15, CYBER_BG);
  tft.setTextSize(1); tft.setTextColor(CYBER_DARK);
  tft.setCursor(8, 228);
  tft.printf("Okunan: %.1fC %.1f%%", curTemp, curHum);
}

// ============================================================
// WiFi
// ============================================================
void connectWiFiAndSyncTime() {
  tft.fillScreen(CYBER_BG); tft.setTextColor(CYBER_LIGHT); tft.setTextSize(1);
  tft.setCursor(20,60); tft.print("Connecting WiFi...");
  WiFi.disconnect(true); delay(500); WiFi.mode(WIFI_STA); delay(100);
  WiFi.begin(ssid, password);
  uint8_t retry=0;
  while(WiFi.status()!=WL_CONNECTED&&retry<40){delay(500);tft.print(".");retry++;}
  if(WiFi.status()==WL_CONNECTED){
    tft.fillScreen(CYBER_BG); tft.setCursor(20,60); tft.setTextColor(CYBER_GREEN);
    tft.print("WiFi OK: "); tft.print(WiFi.localIP());
    configTime(gmtOffset_sec,daylightOffset_sec,ntpServer);
    tft.setCursor(20,85); tft.print("Time synced (GMT+3)"); delay(500);
    mqttClient.setServer(mqtt_server,mqtt_port); mqttClient.setCallback(mqttCallback);
    mqttClient.setBufferSize(2048);  // Larger buffer for home config JSON
    tft.setCursor(20,110); tft.print("MQTT connecting...");
    connectMqtt();
    tft.setCursor(20,135); if(mqttClient.connected()){tft.setTextColor(CYBER_GREEN);tft.print("MQTT OK!");}
    else{tft.setTextColor(AQ_BAR_ORANGE);tft.print("MQTT retry later...");}
    delay(800);
  } else {
    tft.fillScreen(CYBER_BG); tft.setCursor(20,85); tft.setTextColor(ST77XX_RED);
    tft.print("WiFi FAILED!"); delay(1500);
  }
}

String getTimeStr(char type) {
  struct tm ti; if(!getLocalTime(&ti)) return "--";
  char buf[8];
  if(type=='H')strftime(buf,sizeof(buf),"%H",&ti);
  else if(type=='M')strftime(buf,sizeof(buf),"%M",&ti);
  else if(type=='S')strftime(buf,sizeof(buf),"%S",&ti);
  return String(buf);
}

// ============================================================
// MQTT
// ============================================================
void mqttCallback(char* topic, byte* payload, unsigned int length) {
  String msg=""; for(unsigned int i=0;i<length;i++) msg+=(char)payload[i]; msg.trim();
  String tp = String(topic);
  
  // Alarm ON/OFF from HA
  if(tp==TOPIC_ALARM_SET){
    if(msg=="ON") alarmEnabled=true; else if(msg=="OFF"){alarmEnabled=false; if(alarmRinging){alarmRinging=false;stopMelody();}}
    mqttClient.publish(TOPIC_ALARM_STATE,alarmEnabled?"ON":"OFF",true); drawAlarmIcon();
  }
  
  // Buzzer from HA
  if(tp==TOPIC_BUZZER_SET) {
    playAlarmByIndex(selectedAlarm,false);
  }
  
  // Backlight from HA (0-255)
  if(tp==TOPIC_BL_SET){
    int v=msg.toInt();
    backlightLevel=constrain(v,5,255);
    analogWrite(BL_PIN,backlightLevel);
    publishBacklightState();  // Backlight state
    if(currentMode==MODE_BRIGHT) drawBrightnessScreen(false);
    saveSettings();
  }
  
  
  
  
  // Volume from HA
  if(tp==TOPIC_VOL_SET){
    int v=msg.toInt(); volumeLevel=constrain(v,0,100);
    char b[8]; sprintf(b,"%d",volumeLevel);
    mqttClient.publish(TOPIC_VOL_STATE,b,true);
    saveSettings();
  }
  
  // Temperature calibration from HA
  if(tp==TOPIC_TCAL_SET){
    tempOffset=constrain(msg.toFloat(),-15.0f,15.0f);
    char b[8]; dtostrf(tempOffset,4,1,b);
    mqttClient.publish(TOPIC_TCAL_STATE,b,true);
    saveSettings();
  }
  
  // Humidity calibration from HA
  if(tp==TOPIC_HCAL_SET){
    humOffset=constrain(msg.toFloat(),-20.0f,20.0f);
    char b[8]; dtostrf(humOffset,4,1,b);
    mqttClient.publish(TOPIC_HCAL_STATE,b,true);
    saveSettings();
  }
  
  // Sleep mode from HA
  if(tp==TOPIC_SLEEP_SET){
    if(msg=="ON") enterSleep();
    else if(msg=="OFF") wakeUp();
  }
  
  // Auto-sleep enable/disable from HA (persistent)
  if(tp==TOPIC_AUTOSLEEP_SET){
    if(msg=="ON"){
      if(sleepTimeoutMs==0){ sleepTimeoutMs=60000; sleepOptionIndex=2; }  // Default 1min
    } else if(msg=="OFF"){
      sleepTimeoutMs=0; sleepOptionIndex=0;
    }
    mqttClient.publish(TOPIC_AUTOSLEEP_STATE, sleepTimeoutMs>0?"ON":"OFF", true);
    resetActivityTimer();
    saveSettings();
    if(currentMode==MODE_SETTINGS) drawSettingsScreen(false);
  }
  
  // Smart Home config from HA
  if(tp==TOPIC_HOME_CONFIG){
    homeParseConfig(msg.c_str());
    if(currentMode==MODE_HOME) drawHomeScreen();
  }
  
  // Smart Home state updates from HA (individual device)
  // Format: cyberclock/home/state with JSON {"e":"light.salon","s":"on","b":128}
  if(tp==TOPIC_HOME_STATE){
    JsonDocument sdoc;
    if(!deserializeJson(sdoc, msg)){
      const char* eid = sdoc["e"] | "";
      const char* st = sdoc["s"] | "";
      int br = sdoc["b"] | -1;
      // Find device and update
      for(int r=0;r<homeRoomCount;r++)
        for(int d=0;d<homeRooms[r].deviceCount;d++){
          if(strcmp(homeRooms[r].devices[d].entity, eid)==0){
            if(strlen(st)>0) strlcpy(homeRooms[r].devices[d].state, st, 8);
            if(br>=0) homeRooms[r].devices[d].brightness = br;
          }
        }
      if(currentMode==MODE_HOME) drawHomeScreen();
    }
  }

  // Weather data from HA
  // Format: {"temp":18.5,"hum":45,"cond":"Açık","wind":12.3}
  if(tp==TOPIC_WEATHER){
    JsonDocument wdoc;
    if(!deserializeJson(wdoc, msg)){
      weatherTemp = wdoc["temp"] | 0.0f;
      weatherHum = wdoc["hum"] | 0;
      weatherWind = wdoc["wind"] | 0.0f;
      const char* c = wdoc["cond"] | "";
      strlcpy(weatherCond, c, sizeof(weatherCond));
      weatherValid = true;
      if(currentMode==MODE_CLOCK) drawWeather();
    }
  }
}

void publishMqttDiscovery() {
  // Sensors + Alarm + Buzzer
  struct{const char*c;const char*id;const char*n;const char*st;const char*ct;const char*u;const char*dc;}
  ent[]={
    {"sensor","cyberclock_temp","Cyber Clock Temperature",TOPIC_TEMP,NULL,"°C","temperature"},
    {"sensor","cyberclock_hum","Cyber Clock Humidity",TOPIC_HUM,NULL,"%","humidity"},
    {"sensor","cyberclock_tvoc","Cyber Clock TVOC",TOPIC_TVOC,NULL,"ppb",NULL},
    {"sensor","cyberclock_co2","Cyber Clock CO2",TOPIC_CO2,NULL,"ppm","carbon_dioxide"},
    {"switch","cyberclock_alarm","Cyber Clock Alarm",TOPIC_ALARM_STATE,TOPIC_ALARM_SET,NULL,NULL},
    {"button","cyberclock_buzzer","Cyber Clock Buzzer",NULL,TOPIC_BUZZER_SET,NULL,NULL},
  };
  for(int i=0;i<6;i++){
    JsonDocument doc; doc["name"]=ent[i].n; doc["uniq_id"]=ent[i].id;
    doc["dev"]["ids"][0]="cyberclock_01"; doc["dev"]["name"]="Cyber Clock";
    doc["dev"]["mf"]="DIY"; doc["dev"]["mdl"]="Smart Cyber Clock v10.1-ST7789";
    if(ent[i].st)doc["stat_t"]=ent[i].st; if(ent[i].ct)doc["cmd_t"]=ent[i].ct;
    if(ent[i].u)doc["unit_of_meas"]=ent[i].u; if(ent[i].dc)doc["dev_cla"]=ent[i].dc;
    char t[128],b[512]; sprintf(t,"homeassistant/%s/%s/config",ent[i].c,ent[i].id);
    serializeJson(doc,b); mqttClient.publish(t,b,true);
  }

  // ===== Backlight brightness — number entity (5-255) =====
  {JsonDocument doc; doc["name"]="Cyber Clock Parlaklik"; doc["cmd_t"]=TOPIC_BL_SET;
   doc["stat_t"]=TOPIC_BL_STATE; doc["min"]=5; doc["max"]=255;
   doc["step"]=5; doc["icon"]="mdi:brightness-6";
   doc["uniq_id"]="cyberclock_backlight"; doc["dev"]["ids"][0]="cyberclock_01";
   doc["dev"]["name"]="Cyber Clock"; char b[512]; serializeJson(doc,b);
   mqttClient.publish("homeassistant/number/cyberclock_backlight/config",b,true);}

  // Remove old Backlight entities
  mqttClient.publish("homeassistant/switch/cyberclock_led_switch/config", "", true);
  mqttClient.publish("homeassistant/number/cyberclock_led_dimmer/config", "", true);
  mqttClient.publish("homeassistant/select/cyberclock_ledmode/config", "", true);

  // Volume number
  {JsonDocument doc; doc["name"]="Cyber Clock Volume"; doc["cmd_t"]=TOPIC_VOL_SET;
   doc["stat_t"]=TOPIC_VOL_STATE; doc["min"]=0; doc["max"]=100;
   doc["unit_of_meas"]="%"; doc["icon"]="mdi:volume-high";
   doc["uniq_id"]="cyberclock_vol"; doc["dev"]["ids"][0]="cyberclock_01";
   doc["dev"]["name"]="Cyber Clock"; char b[512]; serializeJson(doc,b);
   mqttClient.publish("homeassistant/number/cyberclock_vol/config",b,true);}

  // Temp calibration number
  {JsonDocument doc; doc["name"]="Cyber Clock Temp Offset"; doc["cmd_t"]=TOPIC_TCAL_SET;
   doc["stat_t"]=TOPIC_TCAL_STATE; doc["min"]=-15; doc["max"]=15;
   doc["step"]=0.5; doc["unit_of_meas"]="°C"; doc["icon"]="mdi:thermometer-alert";
   doc["uniq_id"]="cyberclock_tcal"; doc["dev"]["ids"][0]="cyberclock_01";
   doc["dev"]["name"]="Cyber Clock"; char b[512]; serializeJson(doc,b);
   mqttClient.publish("homeassistant/number/cyberclock_tcal/config",b,true);}

  // Hum calibration number
  {JsonDocument doc; doc["name"]="Cyber Clock Hum Offset"; doc["cmd_t"]=TOPIC_HCAL_SET;
   doc["stat_t"]=TOPIC_HCAL_STATE; doc["min"]=-20; doc["max"]=20;
   doc["step"]=1; doc["unit_of_meas"]="%"; doc["icon"]="mdi:water-percent";
   doc["uniq_id"]="cyberclock_hcal"; doc["dev"]["ids"][0]="cyberclock_01";
   doc["dev"]["name"]="Cyber Clock"; char b[512]; serializeJson(doc,b);
   mqttClient.publish("homeassistant/number/cyberclock_hcal/config",b,true);}

  // Sleep mode switch
  {JsonDocument doc; doc["name"]="Cyber Clock Uyku"; doc["cmd_t"]=TOPIC_SLEEP_SET;
   doc["stat_t"]=TOPIC_SLEEP_STATE; doc["icon"]="mdi:sleep";
   doc["uniq_id"]="cyberclock_sleep"; doc["dev"]["ids"][0]="cyberclock_01";
   doc["dev"]["name"]="Cyber Clock"; char b[512]; serializeJson(doc,b);
   mqttClient.publish("homeassistant/switch/cyberclock_sleep/config",b,true);}

  // Auto-sleep enable/disable switch
  {JsonDocument doc; doc["name"]="Cyber Clock Oto Uyku"; doc["cmd_t"]=TOPIC_AUTOSLEEP_SET;
   doc["stat_t"]=TOPIC_AUTOSLEEP_STATE; doc["icon"]="mdi:sleep-off";
   doc["uniq_id"]="cyberclock_autosleep"; doc["dev"]["ids"][0]="cyberclock_01";
   doc["dev"]["name"]="Cyber Clock"; char b[512]; serializeJson(doc,b);
   mqttClient.publish("homeassistant/switch/cyberclock_autosleep/config",b,true);}

  // ===== Remove old entities that are no longer used =====

  Serial.println("MQTT Discovery v7 published");
}

void connectMqtt() {
  if(mqttClient.connected()) return;
  unsigned long now=millis(); if(now-lastMqttReconnect<MQTT_RECONNECT_INTERVAL) return;
  lastMqttReconnect=now;
  if(mqttClient.connect(mqtt_client_id,mqtt_user,mqtt_password,TOPIC_STATUS,0,true,"offline")){
    mqttClient.publish(TOPIC_STATUS,"online",true);
    mqttClient.subscribe(TOPIC_ALARM_SET);
    mqttClient.subscribe(TOPIC_BUZZER_SET);
    mqttClient.subscribe(TOPIC_BL_SET);        // Backlight
    mqttClient.subscribe(TOPIC_VOL_SET);
    mqttClient.subscribe(TOPIC_TCAL_SET);
    mqttClient.subscribe(TOPIC_HCAL_SET);
    mqttClient.subscribe(TOPIC_SLEEP_SET);
    mqttClient.subscribe(TOPIC_AUTOSLEEP_SET);
    mqttClient.subscribe(TOPIC_HOME_CONFIG);
    mqttClient.subscribe(TOPIC_HOME_STATE);
    mqttClient.subscribe(TOPIC_WEATHER);
    publishMqttDiscovery();
    mqttClient.publish(TOPIC_ALARM_STATE,alarmEnabled?"ON":"OFF",true);
    publishBacklightState();  // Backlight state
    char vb[8]; sprintf(vb,"%d",volumeLevel); mqttClient.publish(TOPIC_VOL_STATE,vb,true);
    char tb[8]; dtostrf(tempOffset,4,1,tb); mqttClient.publish(TOPIC_TCAL_STATE,tb,true);
    char hb[8]; dtostrf(humOffset,4,1,hb); mqttClient.publish(TOPIC_HCAL_STATE,hb,true);
    mqttClient.publish(TOPIC_SLEEP_STATE, screenSleeping?"ON":"OFF", true);
    mqttClient.publish(TOPIC_AUTOSLEEP_STATE, sleepTimeoutMs>0?"ON":"OFF", true);
  }
}

void publishSensorData() {
  if(!mqttClient.connected()) return;
  unsigned long now=millis(); if(now-lastMqttPublish<MQTT_PUBLISH_INTERVAL) return;
  lastMqttPublish=now; char buf[16];
  dtostrf(curTemp,4,1,buf); mqttClient.publish(TOPIC_TEMP,buf);
  dtostrf(curHum,4,1,buf); mqttClient.publish(TOPIC_HUM,buf);
  sprintf(buf,"%d",curTVOC); mqttClient.publish(TOPIC_TVOC,buf);
  sprintf(buf,"%d",curECO2); mqttClient.publish(TOPIC_CO2,buf);
}

// ============================================================
// Env Sensors
// ============================================================
void updateEnvSensors(bool force) {
  unsigned long now=millis(); if(!force&&(now-lastEnvRead)<5000) return; lastEnvRead=now;
  sensors_event_t hum,temp;
  if(aht.getEvent(&hum,&temp)){
    curTemp=temp.temperature + tempOffset;
    curHum=constrain(hum.relative_humidity + humOffset, 0.0f, 100.0f);
  }
  // ENS160: measure and read
  ens160.set_envdata(curTemp, curHum);
  ensLastStatus = ens160.measure();
  // Read values regardless of status (some library versions return 1 even with valid data)
  uint16_t nT=ens160.getTVOC();
  uint16_t nC=ens160.geteCO2();
  if(nT!=0xFFFF && nT!=0 && nT<20000) curTVOC=nT;
  if(nC!=0xFFFF && nC!=0 && nC>=400 && nC<20000) curECO2=nC;
  // If stuck in status!=0, periodically re-init ENS160
  if(ensLastStatus != 0) {
    static unsigned long lastEnsRetry = 0;
    if(millis() - lastEnsRetry > 15000) {
      lastEnsRetry = millis();
      Wire.end(); delay(50); Wire.begin(SDA_PIN,SCL_PIN); delay(50);
      ens160.begin();
      delay(50);
      ens160.setMode(ENS160_OPMODE_STD);
      delay(50);
      // Re-init AHT too since we reset Wire
      aht.begin();
    }
  }
}

// ============================================================
// Clock UI
// ============================================================
// ====== Clock UI Layout (320x240) ======
// Saat (y=15), Nem+Sıcaklık (y=78), Tarih (y=140), Hava durumu (y=185)
const int GRID_L=8,GRID_R=312,GRID_TOP=78,GRID_MID=130;
const int GRID_MID_X=(GRID_L+GRID_R)/2;
const int TOP_LABEL_Y=GRID_TOP+4,TOP_VALUE_Y=GRID_TOP+20;
const int DATE_Y=142;
const int WEATHER_Y=185;

void printCenteredText(const String &t,int x0,int x1,int y,uint16_t c,uint16_t bg,uint8_t s=1){
  int16_t bx,by;uint16_t w,h;tft.setTextSize(s);tft.getTextBounds(t,0,0,&bx,&by,&w,&h);
  tft.setTextColor(c,bg);tft.setCursor(x0+((x1-x0)-(int)w)/2,y);tft.print(t);}

uint16_t colorForCO2(uint16_t e){if(e<=800)return AQ_BAR_GREEN;if(e<=1200)return AQ_BAR_YELLOW;if(e<=1600)return AQ_BAR_ORANGE;return AQ_BAR_RED;}

// Turkish day/month names
const char* turkGun[] = {"Pazar","Pazartesi","Sali","Carsamba","Persembe","Cuma","Cumartesi"};
const char* turkAy[] = {"","Ocak","Subat","Mart","Nisan","Mayis","Haziran","Temmuz","Agustos","Eylul","Ekim","Kasim","Aralik"};

void drawDate() {
  time_t now; time(&now);
  struct tm ti; localtime_r(&now, &ti);
  char buf[40];
  sprintf(buf, "%d %s %d %s", ti.tm_mday, turkAy[ti.tm_mon+1], ti.tm_year+1900, turkGun[ti.tm_wday]);
  tft.fillRect(GRID_L, DATE_Y-2, GRID_R-GRID_L, 28, CYBER_BG);
  printCenteredText(String(buf), GRID_L, GRID_R, DATE_Y, CLR_DATE, CYBER_BG, 2);
}

// Translate HA weather condition to Turkish
const char* translateWeather(const char* cond) {
  if (strcmp(cond, "sunny") == 0) return "Gunesli";
  if (strcmp(cond, "clear-night") == 0) return "Acik";
  if (strcmp(cond, "partlycloudy") == 0) return "Parcali Bulutlu";
  if (strcmp(cond, "cloudy") == 0) return "Bulutlu";
  if (strcmp(cond, "rainy") == 0) return "Yagmurlu";
  if (strcmp(cond, "pouring") == 0) return "Saganak";
  if (strcmp(cond, "snowy") == 0) return "Karli";
  if (strcmp(cond, "snowy-rainy") == 0) return "Karla Karisik";
  if (strcmp(cond, "fog") == 0) return "Sisli";
  if (strcmp(cond, "hail") == 0) return "Dolu";
  if (strcmp(cond, "lightning") == 0) return "Firtina";
  if (strcmp(cond, "lightning-rainy") == 0) return "Gokgurultusu";
  if (strcmp(cond, "windy") == 0) return "Ruzgarli";
  if (strcmp(cond, "windy-variant") == 0) return "Ruzgarli";
  if (strcmp(cond, "exceptional") == 0) return "Olagandisi";
  return cond;
}

void drawWeather() {
  tft.fillRect(GRID_L, WEATHER_Y-2, GRID_R-GRID_L, 50, CYBER_BG);
  if (!weatherValid) {
    printCenteredText("Hava durumu bekleniyor...", GRID_L, GRID_R, WEATHER_Y+8, CYBER_GREY, CYBER_BG, 1);
    return;
  }
  // Weather condition + temperature (large)
  char buf[64];
  sprintf(buf, "%s  %.1f'C", translateWeather(weatherCond), weatherTemp);
  printCenteredText(String(buf), GRID_L, GRID_R, WEATHER_Y, CLR_WEATHER, CYBER_BG, 3);
  // Humidity + Wind (smaller, below)
  sprintf(buf, "Nem: %d%%   Ruzgar: %.1f km/h", weatherHum, weatherWind);
  printCenteredText(String(buf), GRID_L, GRID_R, WEATHER_Y+30, CLR_WDETAIL, CYBER_BG, 1);
}

void initClockStaticUI() {
  tft.fillScreen(CYBER_BG);

  // MQTT indicator (top right, subtle)
  if(mqttClient.connected()){
    tft.setTextSize(1);tft.setTextColor(CYBER_GREEN);
    tft.setCursor(280,4);tft.print("MQTT");
  }

  // Grid lines (soft grey)
  tft.drawFastHLine(GRID_L,GRID_TOP,GRID_R-GRID_L,CYBER_GREY);
  tft.drawFastHLine(GRID_L,GRID_MID,GRID_R-GRID_L,CYBER_GREY);
  tft.drawFastVLine(GRID_MID_X,GRID_TOP,GRID_MID-GRID_TOP,CYBER_GREY);

  // Labels (textSize 1, soft grey)
  printCenteredText("Nem",GRID_L,GRID_MID_X,TOP_LABEL_Y,CYBER_GREY,CYBER_BG,1);
  printCenteredText("Sicaklik",GRID_MID_X,GRID_R,TOP_LABEL_Y,CYBER_GREY,CYBER_BG,1);

  // Date separator
  tft.drawFastHLine(GRID_L, WEATHER_Y-8, GRID_R-GRID_L, CYBER_GREY);

  drawAlarmIcon();
  drawDate();
  drawWeather();
}

void drawClockTime(String hS,String mS,String sS){
  String c=hS+":"+mS+":"+sS; if(c==prevTimeStr)return; prevTimeStr=c;
  int16_t x1,y1;uint16_t w,h; tft.setTextSize(6);tft.getTextBounds(c,0,0,&x1,&y1,&w,&h);
  tft.setTextColor(CLR_CLOCK,CYBER_BG);tft.setCursor((320-w)/2,15);tft.print(c);}

void drawCO2Value(uint16_t e,uint16_t c){} // ENS160 disabled — stub

void drawEnvDynamic(float t,float h,uint16_t tv,uint16_t e){
  char b[16];
  // Clear value areas before redraw (prevent text ghosting)
  int valH = 28;
  tft.fillRect(GRID_L+1, TOP_VALUE_Y-2, GRID_MID_X-GRID_L-2, valH, CYBER_BG);
  tft.fillRect(GRID_MID_X+1, TOP_VALUE_Y-2, GRID_R-GRID_MID_X-2, valH, CYBER_BG);

  sprintf(b,"%.0f%%",h);printCenteredText(String(b),GRID_L,GRID_MID_X,TOP_VALUE_Y,CLR_HUM,CYBER_BG,3);
  sprintf(b,"%.1fC",t);printCenteredText(String(b),GRID_MID_X,GRID_R,TOP_VALUE_Y,CLR_TEMP,CYBER_BG,3);

  // Update date every minute
  static int lastMin = -1;
  time_t now; time(&now);
  struct tm ti; localtime_r(&now, &ti);
  if(ti.tm_min != lastMin){ lastMin = ti.tm_min; drawDate(); }
}

// ============================================================
// Menu
// ============================================================
// Scrolling menu: shows MENU_VISIBLE items at a time
#define MENU_VISIBLE 7
int menuScrollOffset = 0;

void drawMenu() {
  tft.fillScreen(CYBER_BG); tft.setTextSize(1); tft.setTextColor(CYBER_LIGHT);
  tft.setTextSize(2);tft.setCursor(20,8); tft.print("MOD SEC");
  if(mqttClient.connected()){tft.setTextColor(CYBER_GREEN);tft.setCursor(220,10);tft.print("[MQTT]");}
  const char* items[MENU_ITEMS]={"Monitor","Pomodoro","Alarm","Oyunlar","Parlaklik","Ev","Ayarlar","Uyku"};
  tft.setTextSize(2);
  
  // Keep selected item in visible window
  if(menuIndex < menuScrollOffset) menuScrollOffset = menuIndex;
  if(menuIndex >= menuScrollOffset + MENU_VISIBLE) menuScrollOffset = menuIndex - MENU_VISIBLE + 1;
  if(menuScrollOffset < 0) menuScrollOffset = 0;
  
  for(int vi=0; vi<MENU_VISIBLE && (menuScrollOffset+vi)<MENU_ITEMS; vi++){
    int i = menuScrollOffset + vi;
    int y = 35 + vi * 28;
    if(i==menuIndex){tft.fillRoundRect(10,y-4,300,24,4,CYBER_ACCENT);tft.setTextColor(CYBER_BG);}
    else{tft.fillRoundRect(10,y-4,300,24,4,0x18E3);tft.setTextColor(ST77XX_WHITE);}
    tft.setCursor(20,y);tft.print(items[i]);
    if(i==3 || i==5){
      if(i==menuIndex) tft.setTextColor(CYBER_BG);
      else tft.setTextColor(CYBER_DARK);
      tft.setCursor(145, y); tft.print(">");
    }
  }
  // Scroll indicators
  if(menuScrollOffset > 0){tft.setTextColor(CYBER_DARK);tft.setCursor(155,25);tft.print("^");}
  if(menuScrollOffset + MENU_VISIBLE < MENU_ITEMS){tft.setTextColor(CYBER_DARK);tft.setCursor(155,35+MENU_VISIBLE*28);tft.print("v");}
  drawAlarmIcon();
}

