const int ALARM_COUNT = 8;

// Parsed alarm cache
int parsedAlarmIdx = -1;

void playAlarmByIndex(int idx, bool loop) {
  if(idx < 0 || idx >= ALARM_COUNT) idx = 0;
  parseRTTTL(rtttlAlarms[idx]);
  parsedAlarmIdx = idx;
  startMelody(rtttlNotes, rtttlDurs, rtttlLen, loop);
}

