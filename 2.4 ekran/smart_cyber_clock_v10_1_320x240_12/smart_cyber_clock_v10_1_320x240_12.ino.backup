// ============================================================
// SLEEP MODE
// ============================================================
void enterDim() {
  if (screenDimmed || screenSleeping) return;
  screenDimmed = true;
  dimStartMs = millis();
  analogWrite(BL_PIN, constrain(backlightLevel * 1 / 100, 1, 3));  // ~1% brightness
  Serial.println("Screen dimmed");
}

void exitDim() {
  if (!screenDimmed) return;
  screenDimmed = false;
  analogWrite(BL_PIN, backlightLevel);  // Restore full brightness
}

void enterSleep() {
  if (screenSleeping) return;
  screenSleeping = true;
  screenDimmed = false;
  preSleepMode = currentMode;
  currentMode = MODE_SLEEP;
  
  // Restore landscape if in Tetris portrait mode
  // Tetris now uses landscape — no rotation restore needed
  
  // Turn off backlight completely
  analogWrite(BL_PIN, 0);
  
  // Publish sleep state to HA
  if (mqttClient.connected()) {
    mqttClient.publish(TOPIC_SLEEP_STATE, "ON", true);
  }
  Serial.println("Sleep mode ON — backlight OFF");
}

void wakeUp() {
  if (!screenSleeping) return;
  screenSleeping = false;
  screenDimmed = false;
  lastActivityMs = millis();
  
  // Restore backlight
  analogWrite(BL_PIN, backlightLevel);
  
  // Restore previous mode
  currentMode = preSleepMode;
  
  // Redraw current screen
  switch (currentMode) {
    case MODE_CLOCK:
      initClockStaticUI(); prevTimeStr = "";
      drawClockTime(getTimeStr('H'), getTimeStr('M'), getTimeStr('S'));
      drawEnvDynamic(curTemp, curHum, curTVOC, curECO2);
      break;
    case MODE_MENU: drawMenu(); break;
    case MODE_GAMES_MENU: drawGamesMenu(); break;
    case MODE_POMODORO: drawPomodoroScreen(true); break;
    case MODE_ALARM: drawAlarmScreen(true); break;
    case MODE_BRIGHT: drawBrightnessScreen(true); break;
    case MODE_SETTINGS: drawSettingsScreen(true); break;
    default: 
      currentMode = MODE_CLOCK;
      initClockStaticUI(); prevTimeStr = "";
      drawClockTime(getTimeStr('H'), getTimeStr('M'), getTimeStr('S'));
      drawEnvDynamic(curTemp, curHum, curTVOC, curECO2);
      break;
  }
  
  // Publish wake state to HA
  if (mqttClient.connected()) {
    mqttClient.publish(TOPIC_SLEEP_STATE, "OFF", true);
  }
  Serial.println("Sleep mode OFF");
}

void resetActivityTimer() {
  lastActivityMs = millis();
}

// Publish LED ON/OFF state + dimmer brightness + mode to HA
void publishBacklightState() {
  if (!mqttClient.connected()) return;
  char buf[8]; sprintf(buf, "%d", backlightLevel);
  mqttClient.publish(TOPIC_BL_STATE, buf, true);
}

